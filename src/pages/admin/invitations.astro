    <script define:vars={{ base }}>
      const PERKS = {
        vvip: ['Reserved Premium Seating','Reserved Parking','Complimentary Refreshments','Professionally Catered Dinner','Meet & Greet with Guest of Honor'],
        vip: ['Reserved Seating','Reserved Parking','Complimentary Refreshments','Professionally Catered Dinner','Meet & Greet with Guest of Honor'],
        sponsor: ['Reserved Seating','Reserved Parking','Complimentary Refreshments','Professionally Catered Dinner','Meet & Greet with Guest of Honor'],
        regular: ['Free Parking','General Seating','Dinner Included'],
        chaayamukhi: ['Free Entry','General Seating']
      };
      const LABELS = { vvip:'VVIP', vip:'VIP', sponsor:'Sponsor', regular:'Guest', chaayamukhi:'Chaayamukhi' };

      let invitees = [], curIdx = -1, selType = 'regular', selFmt = '1page';

      // DOM
      const w1 = document.getElementById('preview-1p');
      const w2 = document.getElementById('preview-2p');
      const els = (prefix) => ({
        name: document.getElementById(prefix+'-name'),
        title: document.getElementById(prefix+'-title'),
        a1: document.getElementById(prefix+'-a1'),
        a2: document.getElementById(prefix+'-a2'),
        csz: document.getElementById(prefix+'-csz'),
        addr: document.getElementById(prefix+'-addr'),
        badge: document.getElementById(prefix+'-badge'),
        perks: document.getElementById(prefix+'-perks'),
        sp: document.getElementById(prefix+'-sp'),
      });
      const p1 = els('p1'), p2 = els('p2');
      const wCh = document.getElementById('preview-ch');
      const ch = {
        name: document.getElementById('ch-name'),
        title: document.getElementById('ch-title'),
        a1: document.getElementById('ch-a1'),
        a2: document.getElementById('ch-a2'),
        csz: document.getElementById('ch-csz'),
        addr: document.getElementById('ch-addr'),
      };
      const iList = document.getElementById('invitee-list');
      const iSec = document.getElementById('invitee-section');
      const iCount = document.getElementById('invitee-count');
      const pac = document.getElementById('print-all-container');
      const inp = {
        name: document.getElementById('inp-name'), title: document.getElementById('inp-title'),
        a1: document.getElementById('inp-addr1'), a2: document.getElementById('inp-addr2'),
        csz: document.getElementById('inp-csz')
      };

      // FORMAT
      document.querySelectorAll('.format-btn').forEach(b => b.addEventListener('click', () => {
        selFmt = b.dataset.format;
        document.querySelectorAll('.format-btn').forEach(x => x.classList.remove('active'));
        b.classList.add('active');
        w1.style.display = selFmt === '1page' ? '' : 'none';
        w2.style.display = selFmt === '2page' ? '' : 'none';
        refresh();
      }));

      // TYPE
      const tBtns = document.querySelectorAll('.type-btn');
      tBtns.forEach(b => b.addEventListener('click', () => {
        selType = b.dataset.type;
        tBtns.forEach(x => x.classList.remove('active-vvip','active-vip','active-sponsor','active-regular','active-chaayamukhi'));
        b.classList.add('active-' + selType);
        refresh();
      }));

      // LIVE PREVIEW
      Object.values(inp).forEach(i => i.addEventListener('input', refresh));

      function refresh() {
        // If an invitee from the list is selected, use their data (keeps name visible when switching types)
        if (curIdx >= 0 && invitees[curIdx]) {
          const v = invitees[curIdx];
          apply(v.name, v.title, v.a1, v.a2, v.csz, selType);
          return;
        }
        // Otherwise use form inputs
        const n = inp.name.value.trim() || 'Guest Name';
        const t = inp.title.value.trim();
        const a1 = inp.a1.value.trim(), a2 = inp.a2.value.trim(), c = inp.csz.value.trim();
        apply(n, t, a1, a2, c, selType);
      }

      function perksHtml(type) {
        return PERKS[type].map(p => {
          const isDinner = p.toLowerCase().includes('dinner') || p.toLowerCase().includes('catered');
          return '<li><span class="pk-dot"></span><span' + (isDinner ? ' class="perk-highlight"' : '') + '>' + p + '</span></li>';
        }).join('');
      }

      function apply(name, title, a1, a2, csz, type) {
        const isCh = type === 'chaayamukhi';

        // Update standard templates
        [p1, p2].forEach(p => {
          p.name.textContent = name || 'Guest Name';
          p.title.textContent = title; p.title.style.display = title ? '' : 'none';
          p.a1.textContent = a1; p.a2.textContent = a2; p.csz.textContent = csz;
          p.addr.style.display = (a1||a2||csz) ? '' : 'none';
          p.badge.textContent = LABELS[type]; p.badge.className = 'inv-badge';
          p.sp.style.display = type === 'sponsor' ? '' : 'none';
          p.perks.innerHTML = perksHtml(type);
        });

        // Update chaayamukhi template
        ch.name.textContent = name || 'Guest Name';
        ch.title.textContent = title; ch.title.style.display = title ? '' : 'none';
        ch.a1.textContent = a1; ch.a2.textContent = a2; ch.csz.textContent = csz;
        ch.addr.style.display = (a1||a2||csz) ? '' : 'none';

        // Show/hide the right template
        if (isCh) {
          w1.style.display = 'none';
          w2.style.display = 'none';
          wCh.style.display = '';
        } else {
          wCh.style.display = 'none';
          w1.className = 't-' + type;
          w2.className = 't-' + type;
          w1.style.display = selFmt === '1page' ? '' : 'none';
          w2.style.display = selFmt === '2page' ? '' : 'none';
        }
      }

      // ADD
      document.getElementById('btn-add').addEventListener('click', addInv);
      document.getElementById('btn-preview').addEventListener('click', refresh);

      function addInv() {
        const n = inp.name.value.trim();
        if (!n) { inp.name.focus(); inp.name.style.borderBottomColor = '#8b1a1a'; setTimeout(() => inp.name.style.borderBottomColor = '', 1500); return; }
        invitees.push({ name: n, title: inp.title.value.trim(), a1: inp.a1.value.trim(), a2: inp.a2.value.trim(), csz: inp.csz.value.trim(), type: selType });
        Object.values(inp).forEach(i => i.value = '');
        renderList(); preview(invitees.length - 1);
        enableBulkBtn();
      }

      function renderList() {
        if (!invitees.length) { iSec.classList.add('hidden'); return; }
        iSec.classList.remove('hidden');
        iCount.textContent = '(' + invitees.length + ')';
        iList.innerHTML = invitees.map((v,i) => '<div class="invitee-item '+(i===curIdx?'active':'')+'" data-i="'+i+'"><span class="text-cream/30 text-xs font-mono w-5 text-right flex-shrink-0">'+(i+1)+'</span><span class="w-2 h-2 rounded-full flex-shrink-0 badge-'+v.type+'"></span><span class="flex-1 text-sm text-cream/80 truncate">'+v.name+'</span><span class="text-xs text-cream/30 uppercase tracking-wider">'+v.type+'</span><button class="rm text-cream/20 hover:text-crimson transition-colors text-lg leading-none" data-i="'+i+'">&times;</button></div>').join('');
        iList.querySelectorAll('.invitee-item').forEach(el => el.addEventListener('click', e => { if (e.target.classList.contains('rm')) return; preview(+el.dataset.i); }));
        iList.querySelectorAll('.rm').forEach(b => b.addEventListener('click', e => { e.stopPropagation(); invitees.splice(+b.dataset.i, 1); if (curIdx >= invitees.length) curIdx = invitees.length-1; renderList(); if (invitees.length && curIdx >= 0) preview(curIdx); }));
      }

      function preview(i) {
        curIdx = i; const v = invitees[i]; if (!v) return;
        apply(v.name, v.title, v.a1, v.a2, v.csz, v.type);
        // Update banner
        document.getElementById('current-invitee-name').textContent = v.name;
        document.getElementById('current-invitee-type').textContent = v.type.toUpperCase();
        renderList();
        // On mobile, scroll preview into view
        if (window.innerWidth < 1024) {
          document.getElementById('print-zone').scrollIntoView({ behavior: 'smooth' });
        }
      }

      document.getElementById('btn-clear-all').addEventListener('click', () => { invitees = []; curIdx = -1; renderList(); apply('Guest Name','','','','',selType); });

      // CSV
      const dz = document.getElementById('drop-zone'), ci = document.getElementById('csv-input');
      dz.addEventListener('click', () => ci.click());
      dz.addEventListener('dragover', e => { e.preventDefault(); dz.style.borderColor = 'rgba(212,160,23,0.6)'; });
      dz.addEventListener('dragleave', () => { dz.style.borderColor = ''; });
      dz.addEventListener('drop', e => { e.preventDefault(); dz.style.borderColor = ''; const f=e.dataTransfer.files[0]; if (f&&f.name.endsWith('.csv')) parseFile(f); });
      ci.addEventListener('change', e => { if (e.target.files[0]) parseFile(e.target.files[0]); });

      function parseFile(file) {
        const r = new FileReader();
        r.onload = e => {
          const lines = e.target.result.split('\n').map(l=>l.trim()).filter(l=>l);
          if (lines.length < 2) return;
          const hdr = csvLine(lines[0]).map(h=>h.toLowerCase().replace(/"/g,'').trim());
          // Match "full name" first, then any column with "name" but not "email" or "phone"
          let ni = hdr.findIndex(h=>h.includes('full name') || h === 'name');
          if (ni < 0) ni = hdr.findIndex(h=>h.includes('name') && !h.includes('email') && !h.includes('phone') && !h.includes('user'));
          const ti=hdr.findIndex(h=>h === 'title' || h.includes('salutation'));
          const a1i=hdr.findIndex(h=>h.includes('address')&&!h.includes('2')&&!h.includes('email')), a2i=hdr.findIndex(h=>h.includes('address')&&h.includes('2'));
          const csi=hdr.findIndex(h=>h.includes('city')||h.includes('zip')||(h === 'state')), tyi=hdr.findIndex(h=>h.includes('type')||h.includes('class')||h.includes('tier'));
          let added=0;
          for (let i=1;i<lines.length;i++) {
            const f=csvLine(lines[i]); const nm=ni>=0?(f[ni]||'').trim():''; if (!nm) continue;
            let tp=selType;
            if (tyi>=0) { const raw=(f[tyi]||'').trim().toLowerCase(); if(raw==='vvip')tp='vvip';else if(raw==='vip')tp='vip';else if(raw==='sponsor')tp='sponsor';else if(raw==='regular'||raw==='guest')tp='regular'; }
            invitees.push({name:nm,title:ti>=0?(f[ti]||'').trim():'',a1:a1i>=0?(f[a1i]||'').trim():'',a2:a2i>=0?(f[a2i]||'').trim():'',csz:csi>=0?(f[csi]||'').trim():'',type:tp});
            added++;
          }
          renderList();
          if(added>0) {
            preview(invitees.length - added);
            enableBulkBtn();
            document.getElementById('invitee-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
          dz.querySelector('p').textContent='Imported '+added+' invitee'+(added!==1?'s':'')+' — click a name to view';
          setTimeout(()=>{dz.querySelector('p').textContent='Drop CSV here or click to upload';},4000);
        };
        r.readAsText(file);
      }

      function csvLine(line) {
        const r=[]; let c='',q=false;
        for (let i=0;i<line.length;i++) { const ch=line[i]; if(q){if(ch==='"'){if(i+1<line.length&&line[i+1]==='"'){c+='"';i++;}else q=false;}else c+=ch;} else{if(ch==='"')q=true;else if(ch===','){r.push(c);c='';}else c+=ch;} }
        r.push(c); return r;
      }

      // PRINT
