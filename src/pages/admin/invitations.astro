---
import '../../styles/global.css';
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href={`${base}/images/aesthetic/the_18_steps_logo.jpg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet" />
    <title>Invitations | The 18 Steps USA</title>
    <style>
      /* ===== DECORATIVE OVERLAYS ===== */
      .ov-dots {
        position: absolute; inset: 0; pointer-events: none;
        background-image: radial-gradient(rgba(212,160,23,0.035) 1px, transparent 1px);
        background-size: 16px 16px;
      }
      .ov-rings {
        position: absolute; inset: 0; pointer-events: none;
        background:
          radial-gradient(circle at 50% 50%, transparent 30%, rgba(212,160,23,0.012) 30.5%, transparent 31%),
          radial-gradient(circle at 50% 50%, transparent 50%, rgba(212,160,23,0.008) 50.5%, transparent 51%),
          radial-gradient(circle at 50% 50%, transparent 70%, rgba(212,160,23,0.005) 70.5%, transparent 71%);
      }
      /* Radial sacred glow */
      .ov-sacred {
        position: absolute; inset: 0; pointer-events: none;
        background:
          radial-gradient(ellipse at 50% 15%, rgba(212,160,23,0.06) 0%, transparent 50%),
          radial-gradient(ellipse at 50% 85%, rgba(212,160,23,0.03) 0%, transparent 40%);
      }
      /* Edge glow strips */
      .ov-edge-l {
        position: absolute; top: 5%; bottom: 5%; left: 0; width: 1px; pointer-events: none;
        background: linear-gradient(180deg, transparent, rgba(212,160,23,0.12), rgba(212,160,23,0.2), rgba(212,160,23,0.12), transparent);
      }
      .ov-edge-r {
        position: absolute; top: 5%; bottom: 5%; right: 0; width: 1px; pointer-events: none;
        background: linear-gradient(180deg, transparent, rgba(212,160,23,0.12), rgba(212,160,23,0.2), rgba(212,160,23,0.12), transparent);
      }
      .ov-edge-t {
        position: absolute; left: 5%; right: 5%; top: 0; height: 1px; pointer-events: none;
        background: linear-gradient(90deg, transparent, rgba(212,160,23,0.15), transparent);
      }
      .ov-edge-b {
        position: absolute; left: 5%; right: 5%; bottom: 0; height: 1px; pointer-events: none;
        background: linear-gradient(90deg, transparent, rgba(212,160,23,0.15), transparent);
      }
      /* Sponsor edge overrides */
      .t-sponsor .ov-edge-l, .t-sponsor .ov-edge-r { background: linear-gradient(180deg, transparent, rgba(61,124,201,0.1), rgba(61,124,201,0.18), rgba(61,124,201,0.1), transparent); }
      .t-sponsor .ov-edge-t, .t-sponsor .ov-edge-b { background: linear-gradient(90deg, transparent, rgba(61,124,201,0.12), transparent); }
      .t-sponsor .ov-sacred { background: radial-gradient(ellipse at 50% 15%, rgba(61,124,201,0.05) 0%, transparent 50%), radial-gradient(ellipse at 50% 85%, rgba(61,124,201,0.025) 0%, transparent 40%); }
      /* Inner frame */
      .ov-frame {
        position: absolute; inset: 12px; pointer-events: none;
        border: 1px solid rgba(212,160,23,0.06);
      }
      .t-vvip .ov-frame { border-color: rgba(212,160,23,0.12); }
      .t-sponsor .ov-frame { border-color: rgba(61,124,201,0.08); }
      .t-regular .ov-frame { border-color: rgba(245,240,232,0.04); }

      /* ===== ORNAMENTAL DIVIDER ===== */
      .orn-div {
        display: flex; align-items: center; justify-content: center;
        gap: 0.4rem; width: 60%; margin: 0.8rem auto;
      }
      .orn-div::before, .orn-div::after {
        content: ''; flex: 1; height: 1px;
      }
      .orn-div .diamond {
        width: 7px; height: 7px; transform: rotate(45deg); flex-shrink: 0;
      }

      /* Divider theme colors */
      .t-vvip .orn-div::before, .t-vvip .orn-div::after { background: linear-gradient(to right, transparent, #d4a017, transparent); }
      .t-vvip .orn-div .diamond { background: #d4a017; }
      .t-vip .orn-div::before, .t-vip .orn-div::after { background: linear-gradient(to right, transparent, #d4a017, transparent); }
      .t-vip .orn-div .diamond { background: #d4a017; }
      .t-sponsor .orn-div::before, .t-sponsor .orn-div::after { background: linear-gradient(to right, transparent, #3d7cc9, transparent); }
      .t-sponsor .orn-div .diamond { background: #3d7cc9; }
      .t-regular .orn-div::before, .t-regular .orn-div::after { background: linear-gradient(to right, transparent, rgba(245,240,232,0.15), transparent); }
      .t-regular .orn-div .diamond { background: rgba(245,240,232,0.2); }

      /* ===== HEADING COLORS ===== */
      .t-vvip .hd {
        color: #d4a017;
        background: linear-gradient(135deg, #d4a017, #f0c040, #b8860b);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      }
      /* Ensure block-level headings center properly with gradient text */
      .t-vvip .f-name.hd, .t-vvip .f-event.hd {
        display: block; width: 100%; text-align: center;
      }
      .t-vip .hd { color: #d4a017; }
      .t-sponsor .hd { color: #f0c040; }
      .t-regular .hd { color: #d4a017; }

      /* ===== CORNER ORNAMENTS ===== */
      .crn { position: absolute; pointer-events: none; }
      .crn::before, .crn::after { content: ''; position: absolute; }
      .crn::before { width: 100%; height: 1.5px; }
      .crn::after { width: 1.5px; height: 100%; }
      .crn-tl { top: 16px; left: 16px; }
      .crn-tr { top: 16px; right: 16px; } .crn-tr::before { right: 0; } .crn-tr::after { right: 0; }
      .crn-bl { bottom: 16px; left: 16px; } .crn-bl::before { bottom: 0; } .crn-bl::after { bottom: 0; }
      .crn-br { bottom: 16px; right: 16px; } .crn-br::before { right: 0; bottom: 0; } .crn-br::after { right: 0; bottom: 0; }

      .t-vvip .crn { width: 55px; height: 55px; }
      .t-vvip .crn::before, .t-vvip .crn::after { background: rgba(212,160,23,0.5); }
      .t-vip .crn { width: 40px; height: 40px; }
      .t-vip .crn::before, .t-vip .crn::after { background: rgba(212,160,23,0.35); }
      .t-sponsor .crn { width: 40px; height: 40px; }
      .t-sponsor .crn::before, .t-sponsor .crn::after { background: rgba(61,124,201,0.3); }
      .t-regular .crn { display: none; }

      /* ===== INVITATION PAGE (shared) ===== */
      .inv-page {
        aspect-ratio: 8.5 / 11;
        height: calc(100vh - 2rem);
        max-height: 900px;
        width: auto;
        border-radius: 4px; overflow: hidden;
        position: relative;
        font-family: 'Inter', system-ui, sans-serif;
        transition: all 0.4s ease;
      }

      /* ===== TYPE BACKGROUNDS ===== */
      .t-vvip .inv-page {
        background: linear-gradient(145deg, #1a0a3e 0%, #2d1266 40%, #1a0a3e 100%);
        color: #f5f0e8; border: 2.5px solid #d4a017;
        box-shadow: inset 0 0 0 5px rgba(74,32,128,0.5), inset 0 0 0 7px rgba(212,160,23,0.3), 0 0 40px rgba(212,160,23,0.08);
      }
      .t-vip .inv-page {
        background: linear-gradient(180deg, #0d0d2b 0%, #151540 50%, #0d0d2b 100%);
        color: #f5f0e8; border: 2px solid #d4a017; box-shadow: 0 0 25px rgba(212,160,23,0.08);
      }
      .t-sponsor .inv-page {
        background: linear-gradient(145deg, #0d0d2b 0%, #0d1f3d 50%, #0d0d2b 100%);
        color: #f5f0e8; border: 2px solid #3d7cc9; box-shadow: 0 0 25px rgba(61,124,201,0.08);
      }
      .t-regular .inv-page {
        background: #0d0d2b; color: #f5f0e8;
        border: 1px solid rgba(212,160,23,0.15);
      }

      /* ===== PERK DOTS ===== */
      .pk-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }
      .t-vvip .pk-dot { background: #d4a017; }
      .t-vip .pk-dot { background: #d4a017; }
      .t-sponsor .pk-dot { background: #3d7cc9; }
      .t-regular .pk-dot { background: rgba(245,240,232,0.35); }

      /* ===== BADGE ===== */
      .t-vvip .inv-badge {
        background: linear-gradient(135deg, #d4a017, #f0c040); color: #1a0a3e;
        font-family: 'Cinzel', serif; font-weight: 700;
        padding: 0.3rem 1.8rem; letter-spacing: 0.25em; font-size: 0.7rem;
      }
      .t-vip .inv-badge {
        border: 2px solid #d4a017; color: #d4a017; background: transparent;
        font-family: 'Cinzel', serif; font-weight: 600;
        padding: 0.25rem 1.5rem; letter-spacing: 0.2em; font-size: 0.7rem;
      }
      .t-sponsor .inv-badge {
        background: linear-gradient(135deg, #3d7cc9, #5a9de0); color: #f0c040;
        font-family: 'Cinzel', serif; font-weight: 600;
        padding: 0.25rem 1.5rem; letter-spacing: 0.2em; font-size: 0.7rem;
      }
      .t-regular .inv-badge {
        border: none; color: rgba(245,240,232,0.55);
        background: transparent; font-family: 'Cinzel', serif;
        padding: 0.2rem 1.2rem; letter-spacing: 0.15em; font-size: 0.65rem;
      }

      /* ===== 1-PAGE LAYOUT ===== */
      .inv-1p {
        display: flex; flex-direction: column;
        justify-content: center; align-items: center;
        padding: 3rem 2.5rem; text-align: center;
      }

      /* ===== 2-PAGE WRAPPER ===== */
      .inv-2p-wrap {
        display: flex; flex-direction: column; gap: 1.5rem;
        width: auto;
      }

      /* Cover page */
      .inv-cover { display: flex; flex-direction: column; }
      .cv-hero { position: relative; height: 40%; overflow: hidden; }
      .cv-hero img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }
      .cv-hero-ov {
        position: absolute; inset: 0;
        background: linear-gradient(180deg,
          rgba(13,13,43,0.05) 0%, rgba(13,13,43,0.25) 50%,
          rgba(13,13,43,0.8) 80%, var(--cv-bg, #0d0d2b) 100%);
      }
      .cv-body {
        flex: 1; position: relative; display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 0 2rem 1.2rem; text-align: center;
      }
      .cv-logo-wrap { position: relative; margin-top: -36px; }
      .cv-logo-glow {
        position: absolute; inset: -15px; border-radius: 50%;
        background: radial-gradient(circle, rgba(212,160,23,0.25) 0%, transparent 70%);
      }
      .cv-logo {
        width: 72px; height: 72px; border-radius: 50%; object-fit: cover;
        border: 2.5px solid rgba(212,160,23,0.5);
        box-shadow: 0 0 25px rgba(212,160,23,0.2);
        position: relative;
      }
      .cv-org { font-family: 'Cinzel', serif; font-size: 0.5rem; letter-spacing: 0.3em; text-transform: uppercase; opacity: 0.7; margin-top: 0.5rem; }
      .cv-presents { font-family: 'Playfair Display', serif; font-style: italic; font-size: 0.5rem; opacity: 0.45; margin-top: 0.3rem; }
      .cv-title { font-family: 'Cinzel', serif; font-size: 1.5rem; font-weight: 800; letter-spacing: 0.18em; line-height: 1.15; margin: 0.15rem 0; }
      .cv-sub { font-family: 'Cinzel', serif; font-size: 0.5rem; letter-spacing: 0.3em; opacity: 0.7; }
      .cv-tagline { font-family: 'Playfair Display', serif; font-style: italic; font-size: 0.45rem; opacity: 0.4; margin-top: 0.15rem; }

      .cv-date-block { margin-top: 0.5rem; padding: 0.35rem 1.2rem; border-top: 1px solid rgba(212,160,23,0.15); border-bottom: 1px solid rgba(212,160,23,0.15); }
      .cv-date { font-family: 'Cinzel', serif; font-size: 0.9rem; font-weight: 700; letter-spacing: 0.06em; }
      .cv-day { font-size: 0.4rem; letter-spacing: 0.2em; opacity: 0.45; text-transform: uppercase; }
      .cv-venue { margin-top: 0.35rem; font-size: 0.42rem; opacity: 0.45; line-height: 1.4; }
      .cv-venue strong { opacity: 1; font-size: 0.45rem; }

      .t-vvip { --cv-bg: #1a0a3e; }
      .t-vip, .t-regular { --cv-bg: #0d0d2b; }
      .t-sponsor { --cv-bg: #0d0d2b; }

      /* Details page */
      .inv-details {
        display: flex; flex-direction: column;
        justify-content: center; align-items: center;
        padding: 1.8rem 1.5rem; text-align: center;
      }

      /* Chaayamukhi blended imagery */
      .ch-blend {
        position: relative;
        width: 100%; height: 180px;
        margin: 0.5rem 0 0.4rem;
        overflow: hidden; border-radius: 4px;
      }
      .ch-blend img {
        position: absolute; top: 0; height: 100%;
        width: 34%; object-fit: cover; object-position: center top;
        filter: saturate(0.55) brightness(0.65);
      }
      .ch-blend img:nth-child(1) { left: 0; }
      .ch-blend img:nth-child(2) { left: 33%; }
      .ch-blend img:nth-child(3) { right: 0; width: 34%; }
      .ch-blend::after {
        content: ''; position: absolute; inset: 0;
        background:
          linear-gradient(90deg, var(--cv-bg, #0d0d2b) 0%, transparent 8%, transparent 92%, var(--cv-bg, #0d0d2b) 100%),
          linear-gradient(180deg, transparent 0%, transparent 75%, var(--cv-bg, #0d0d2b) 100%);
        pointer-events: none;
      }
      .t-vvip .ch-blend::after {
        background:
          linear-gradient(90deg, #1a0a3e 0%, transparent 8%, transparent 92%, #1a0a3e 100%),
          linear-gradient(180deg, transparent 0%, transparent 75%, #1a0a3e 100%);
      }
      .t-sponsor .ch-blend::after {
        background:
          linear-gradient(90deg, #0d1530 0%, transparent 8%, transparent 92%, #0d1530 100%),
          linear-gradient(180deg, transparent 0%, transparent 75%, #0d1530 100%);
      }

      /* Schedule */
      .sched { display: grid; grid-template-columns: auto 1fr; gap: 0.05rem 0.4rem; font-size: 0.45rem; text-align: left; width: 100%; max-width: 240px; margin: 0.2rem auto 0; }
      .sched-t { font-variant-numeric: tabular-nums; opacity: 0.35; text-align: right; }
      .sched-e { opacity: 0.55; }
      .sched-e.hl { font-weight: 600; opacity: 0.85; }

      /* RSVP & Donate */
      .rsvp-strip {
        margin-top: 0.7rem; display: flex; align-items: center; justify-content: center; gap: 1.2rem;
        font-size: 0.7rem; opacity: 0.6; font-weight: 500;
      }
      /* Dinner highlight */
      .perk-highlight { font-weight: 700; }
      .t-vvip .perk-highlight { color: #f0c040; }
      .t-vip .perk-highlight { color: #f0c040; }
      .t-sponsor .perk-highlight { color: #5a9de0; }
      .t-regular .perk-highlight { color: #f5f0e8; }
      .rsvp-strip a { text-decoration: underline; text-underline-offset: 2px; }
      .t-vvip .rsvp-strip a { color: #f0c040; }
      .t-vip .rsvp-strip a { color: #d4a017; }
      .t-sponsor .rsvp-strip a { color: #5a9de0; }
      .t-regular .rsvp-strip a { color: rgba(245,240,232,0.6); }

      /* ===== SHARED TYPOGRAPHY ===== */
      .f-cordially { font-family: 'Playfair Display', serif; font-style: italic; font-size: 0.9rem; opacity: 0.65; }
      .f-name { font-family: 'Cinzel', serif; font-size: 1.6rem; font-weight: 700; line-height: 1.2; margin: 0.4rem auto; min-height: 1.8rem; text-align: center; width: 100%; display: block; }
      .f-title { font-family: 'Playfair Display', serif; font-style: italic; font-size: 0.8rem; opacity: 0.65; }
      .f-addr { font-size: 0.7rem; opacity: 0.45; margin-top: 0.15rem; line-height: 1.4; }
      .f-tothe { font-family: 'Playfair Display', serif; font-size: 0.8rem; opacity: 0.65; }
      .f-event { font-family: 'Cinzel', serif; font-size: 1.05rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; margin: 0.2rem 0; }
      .f-logo { width: 70px; height: 70px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(212,160,23,0.5); }
      .f-org { font-family: 'Cinzel', serif; font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; opacity: 0.75; margin-top: 0.5rem; }
      .inv-badge { display: inline-block; margin-top: 0.5rem; text-transform: uppercase; }
      .f-perks { margin-top: 0.5rem; padding: 0; display: flex; flex-wrap: wrap; justify-content: center; gap: 0.3rem 0.8rem; font-size: 0.65rem; list-style: none; }
      .f-perks li { display: inline-flex; align-items: center; gap: 0.3rem; white-space: nowrap; }
      .f-goh { margin-top: 0.7rem; text-align: center; }
      .f-goh-lbl { font-family: 'Playfair Display', serif; font-style: italic; font-size: 0.6rem; opacity: 0.5; }
      .f-goh-name { font-family: 'Cinzel', serif; font-size: 0.8rem; font-weight: 600; margin-top: 0.1rem; }
      .f-goh-role { font-size: 0.55rem; opacity: 0.45; }
      .f-tagline { font-family: 'Playfair Display', serif; font-style: italic; font-size: 0.6rem; opacity: 0.35; margin-top: 0.2rem; }
      .f-sponsor-lbl { font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.55; }

      /* Featured strip */
      .feat-strip { margin-top: 0.8rem; padding: 0.6rem 1.5rem; border: none; text-align: center; }
      .feat-lbl { font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase; opacity: 0.4; }
      .feat-title { font-family: 'Playfair Display', serif; font-weight: 700; font-style: italic; font-size: 1.3rem; margin: 0.15rem 0; }
      .feat-sub { font-family: 'Playfair Display', serif; font-style: italic; font-size: 0.6rem; opacity: 0.5; }

      /* Event details block */
      .ev-details { font-size: 0.75rem; line-height: 1.5; margin-top: 0.4rem; }
      .ev-link {
        color: inherit; text-decoration: none;
        border-bottom: 1px dotted rgba(212,160,23,0.3);
        transition: border-color 0.2s, color 0.2s;
        cursor: pointer;
      }
      .ev-link:hover { border-bottom-color: rgba(212,160,23,0.7); }
      .t-vvip .ev-link:hover { color: #f0c040; }
      .t-vip .ev-link:hover { color: #f0c040; }
      .t-sponsor .ev-link:hover { color: #5a9de0; border-bottom-color: rgba(61,124,201,0.5); }
      .t-regular .ev-link:hover { color: #d4a017; }

      /* ===== CONTROLS ===== */
      .format-btn { cursor: pointer; transition: all 0.3s; border: 1px solid rgba(212,160,23,0.2); background: transparent; color: rgba(245,240,232,0.5); padding: 0.4rem 0.8rem; font-size: 0.75rem; font-family: 'Inter', sans-serif; }
      .format-btn:hover { border-color: rgba(212,160,23,0.4); color: rgba(245,240,232,0.8); }
      .format-btn.active { border-color: #d4a017; color: #d4a017; background: rgba(212,160,23,0.1); }
      .type-btn { cursor: pointer; transition: all 0.3s; border: 2px solid transparent; }
      .type-btn:hover { transform: translateY(-2px); }
      .type-btn.active-vvip { border-color: #4a2080; box-shadow: 0 0 15px rgba(74, 32, 128, 0.3); }
      .type-btn.active-vip { border-color: #d4a017; box-shadow: 0 0 15px rgba(212, 160, 23, 0.3); }
      .type-btn.active-sponsor { border-color: #3d7cc9; box-shadow: 0 0 15px rgba(61, 124, 201, 0.3); }
      .type-btn.active-regular { border-color: rgba(245, 240, 232, 0.3); }
      .form-input { background: transparent; border: none; border-bottom: 1px solid rgba(212, 160, 23, 0.2); color: #f5f0e8; padding: 0.5rem 0; width: 100%; outline: none; font-family: 'Inter', sans-serif; font-size: 0.875rem; transition: border-color 0.3s; }
      .form-input:focus { border-bottom-color: #d4a017; }
      .form-input::placeholder { color: rgba(245, 240, 232, 0.3); }
      .invitee-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem 0.75rem; background: rgba(26, 26, 78, 0.4); border: 1px solid rgba(212, 160, 23, 0.08); border-radius: 0.375rem; cursor: pointer; transition: all 0.2s; }
      .invitee-item:hover { border-color: rgba(212, 160, 23, 0.3); background: rgba(26, 26, 78, 0.7); transform: translateX(2px); }
      .invitee-item.active { border-color: rgba(212, 160, 23, 0.5); background: rgba(26, 26, 78, 0.9); border-left: 3px solid #d4a017; }
      .badge-vvip { background: linear-gradient(135deg, #4a2080, #6b3fa0); }
      .badge-vip { background: linear-gradient(135deg, #d4a017, #b8860b); }
      .badge-sponsor { background: linear-gradient(135deg, #3d7cc9, #5a9de0); }
      .badge-regular { background: rgba(245, 240, 232, 0.15); }

      /* ===== PRINT ===== */
      @media print {
        body * { visibility: hidden; }
        #print-zone, #print-zone * { visibility: visible; }
        #print-zone { position: fixed; inset: 0; display: flex; align-items: center; justify-content: center; background: white; }
        .inv-page, #print-all-container .inv-page {
          width: 7.5in !important; max-width: none !important;
          aspect-ratio: auto !important; height: 10in !important;
          box-shadow: none !important; page-break-after: always;
          -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; color-adjust: exact !important;
        }
        .inv-page:last-child { page-break-after: auto; }
        .inv-2p-wrap { gap: 0 !important; max-width: none !important; width: 100% !important; }
        #print-all-container { visibility: visible !important; display: block !important; position: fixed; inset: 0; }
      }
      #print-all-container { display: none; }

      /* ========================================================
         CHAAYAMUKHI-ONLY INVITATION — SEPARATE THEME
         ======================================================== */
      .ch-inv {
        aspect-ratio: 8.5 / 11;
        height: calc(100vh - 2rem); max-height: 900px; width: auto;
        border-radius: 4px; overflow: hidden; position: relative;
        font-family: 'Playfair Display', Georgia, serif;
        color: #faf3e6;
        background: linear-gradient(170deg, #1a0805 0%, #2a0f0a 30%, #1c0a06 60%, #0e0604 100%);
        border: 2px solid rgba(196, 120, 40, 0.25);
        box-shadow: 0 0 40px rgba(196, 120, 40, 0.06);
      }
      /* Hero image - top portion using background-image for html2canvas compatibility */
      .ch-inv-hero {
        position: absolute; top: 0; left: 0; right: 0; height: 45%;
        overflow: hidden;
        background-size: cover;
        background-position: center 20%;
        filter: saturate(0.8) brightness(0.7);
      }
      .ch-inv-hero img { display: none; } /* hidden, bg-image used instead */
      .ch-inv-hero-ov {
        position: absolute; inset: 0;
        background: linear-gradient(180deg,
          rgba(26,8,5,0.1) 0%,
          rgba(26,8,5,0.3) 40%,
          rgba(26,8,5,0.75) 70%,
          #1a0805 95%);
      }
      /* Warm glow overlays */
      .ch-inv .ch-ov-glow {
        position: absolute; inset: 0; pointer-events: none;
        background:
          radial-gradient(ellipse at 50% 45%, rgba(196,120,40,0.08) 0%, transparent 50%),
          radial-gradient(ellipse at 30% 70%, rgba(180,60,20,0.04) 0%, transparent 40%),
          radial-gradient(ellipse at 70% 80%, rgba(196,120,40,0.04) 0%, transparent 40%);
      }
      /* Fire dot pattern */
      .ch-inv .ch-ov-dots {
        position: absolute; inset: 0; pointer-events: none;
        background-image: radial-gradient(rgba(196,120,40,0.03) 1px, transparent 1px);
        background-size: 14px 14px;
      }
      /* Edge embers */
      .ch-inv .ch-edge-l {
        position: absolute; top: 10%; bottom: 10%; left: 0; width: 1px; pointer-events: none;
        background: linear-gradient(180deg, transparent, rgba(196,120,40,0.15), rgba(220,140,40,0.25), rgba(196,120,40,0.15), transparent);
      }
      .ch-inv .ch-edge-r {
        position: absolute; top: 10%; bottom: 10%; right: 0; width: 1px; pointer-events: none;
        background: linear-gradient(180deg, transparent, rgba(196,120,40,0.15), rgba(220,140,40,0.25), rgba(196,120,40,0.15), transparent);
      }
      /* Inner frame */
      .ch-inv .ch-frame {
        position: absolute; inset: 10px; pointer-events: none;
        border: 1px solid rgba(196,120,40,0.08);
      }
      /* Body content */
      .ch-inv-body {
        position: absolute; bottom: 0; left: 0; right: 0; top: 30%;
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; padding: 1.5rem 2rem 2rem;
        text-align: center; z-index: 2;
      }
      /* Chaayamukhi title */
      .ch-inv-title {
        font-family: 'Playfair Display', serif; font-weight: 700; font-style: italic;
        font-size: 2.2rem; letter-spacing: 0.02em; line-height: 1;
        background: linear-gradient(135deg, #c47828, #e8a842, #c47828);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        color: #c47828;
      }
      .ch-inv-subtitle {
        font-style: italic; font-size: 0.7rem; opacity: 0.55; margin-top: 0.2rem;
      }
      .ch-inv-type {
        font-family: 'Cinzel', serif; font-size: 0.5rem; letter-spacing: 0.3em;
        text-transform: uppercase; opacity: 0.4; margin-top: 0.6rem;
      }
      /* Warm divider */
      .ch-div {
        display: flex; align-items: center; justify-content: center;
        gap: 0.4rem; width: 50%; margin: 0.6rem auto;
      }
      .ch-div::before, .ch-div::after {
        content: ''; flex: 1; height: 1px;
        background: linear-gradient(to right, transparent, rgba(196,120,40,0.3), transparent);
      }
      .ch-div .ch-diamond {
        width: 6px; height: 6px; transform: rotate(45deg); flex-shrink: 0;
        background: rgba(196,120,40,0.5);
      }
      /* Invitee name */
      .ch-inv-cordially {
        font-style: italic; font-size: 0.7rem; opacity: 0.5;
      }
      .ch-inv-guest {
        font-family: 'Cinzel', serif; font-size: 1.4rem; font-weight: 700;
        line-height: 1.2; margin: 0.3rem 0; display: block; width: 100%; text-align: center;
        color: #e8a842;
      }
      .ch-inv-guest-title {
        font-style: italic; font-size: 0.65rem; opacity: 0.5;
      }
      .ch-inv-addr { font-family: 'Inter', sans-serif; font-size: 0.55rem; opacity: 0.35; margin-top: 0.1rem; line-height: 1.3; }
      /* Event info */
      .ch-inv-event {
        font-family: 'Inter', sans-serif; font-size: 0.65rem; line-height: 1.5; margin-top: 0.3rem;
      }
      .ch-inv-event strong { font-weight: 600; }
      .ch-inv-event a { color: inherit; text-decoration: none; border-bottom: 1px dotted rgba(196,120,40,0.3); }
      .ch-inv-event a:hover { border-bottom-color: rgba(196,120,40,0.7); color: #e8a842; }
      /* Cast info */
      .ch-inv-cast {
        font-family: 'Inter', sans-serif; font-size: 0.5rem; opacity: 0.4;
        font-style: italic; margin-top: 0.3rem;
      }
      /* RSVP in warm theme */
      .ch-inv-rsvp {
        font-family: 'Inter', sans-serif; font-size: 0.6rem; opacity: 0.45; margin-top: 0.4rem;
        display: flex; align-items: center; justify-content: center; gap: 0.8rem;
      }
      .ch-inv-rsvp a { color: #e8a842; text-decoration: underline; text-underline-offset: 2px; }
      /* Tagline */
      .ch-inv-foot {
        font-style: italic; font-size: 0.45rem; opacity: 0.25; margin-top: 0.15rem;
      }
      /* Active state for type button */
      .type-btn.active-chaayamukhi { border-color: #c47828; box-shadow: 0 0 15px rgba(196,120,40,0.3); }
      .badge-chaayamukhi { background: linear-gradient(135deg, #c47828, #a05018); }
    </style>
  </head>
