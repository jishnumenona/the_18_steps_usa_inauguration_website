        return '<div class="t-'+v.type+'"><div class="inv-2p-wrap" style="display:block"><div class="inv-page inv-cover"><div class="crn crn-tl"></div><div class="crn crn-tr"></div><div class="crn crn-bl"></div><div class="crn crn-br"></div><div class="cv-hero"><img src="'+base+'/images/aesthetic/main_vishnu.webp"/><div class="cv-hero-ov"></div><div class="ov-dots" style="opacity:0.5"></div></div><div class="cv-body"><div class="ov-rings"></div><div class="cv-logo-wrap"><div class="cv-logo-glow"></div><img src="'+base+'/images/aesthetic/the_18_steps_logo.jpg" class="cv-logo"/></div><p class="cv-org hd">The 18 Steps USA</p>'+ornDiv('35%')+'<p class="cv-presents">presents the</p><h1 class="cv-title hd">Inauguration<br/>Ceremony</h1><p class="cv-sub hd">USA Chapter</p><p class="cv-tagline">Preserving Dharma, Heritage and Humanity</p><div class="cv-date-block"><p class="cv-day">Saturday</p><p class="cv-date hd">June 6, 2026</p><p class="cv-day">2:00 PM Onwards</p></div><div class="cv-venue"><strong>PYLUSD Performing Arts Center</strong><br/>1651 Valencia Ave, Placentia, CA 92870</div></div></div><div class="inv-page inv-details"><div class="crn crn-tl"></div><div class="crn crn-tr"></div><div class="crn crn-bl"></div><div class="crn crn-br"></div><div class="ov-dots"></div><div class="ov-rings"></div><div class="ov-sacred"></div><div class="ov-edge-l"></div><div class="ov-edge-r"></div><div class="ov-edge-t"></div><div class="ov-edge-b"></div><div class="ov-frame"></div><div class="relative z-10 text-center w-full"><p class="f-cordially">cordially invites</p><h1 class="f-name hd">'+v.name+'</h1>'+tl+ad+ornDiv()+'<p class="f-tothe">to the</p><h2 class="f-event hd">Inauguration Ceremony</h2><div class="feat-strip"><p class="feat-lbl">Featuring</p><p class="feat-title hd">Chaayamukhi</p><p class="feat-sub">A Musical Dance Drama — A Mirror of Desire, A Promise to Nature</p><div class="ch-blend"><img src="'+base+'/images/chayamughi/1.jpg"/><img src="'+base+'/images/chayamughi/2.jpg"/><img src="'+base+'/images/chayamughi/3.jpg"/></div><p class="feat-sub" style="margin-top:0.2rem">Indian Classical & Folk Dance · ~40 Performers · Kalari Choreography</p></div>'+ornDiv('25%')+'<p style="font-size:0.4rem;letter-spacing:0.2em;text-transform:uppercase;opacity:0.35">Program</p><div class="sched" style="margin:0.15rem auto 0"><span class="sched-t">2:00 PM</span><span class="sched-e">Invocation & Welcome</span><span class="sched-t">2:10 PM</span><span class="sched-e hl">Inauguration</span><span class="sched-t">2:15 PM</span><span class="sched-e hl">Keynote Address</span><span class="sched-t">3:15 PM</span><span class="sched-e">Presentations & Felicitations</span><span class="sched-t">3:50 PM</span><span class="sched-e">Tea Break</span><span class="sched-t">4:50 PM</span><span class="sched-e hl">Chaayamukhi</span><span class="sched-t">5:50 PM</span><span class="sched-e">Dinner & Social</span></div>'+ornDiv('25%')+sp+'<div class="inv-badge">'+LABELS[v.type]+'</div><ul class="f-perks">'+pk+'</ul><div class="f-goh"><p class="f-goh-lbl">Guest of Honor</p><p class="f-goh-name hd">Sharath A. Haridasan</p><p class="f-goh-role">Founder & Mentor</p></div>'+rsvpStrip()+ornDiv('25%')+'<p class="f-tagline">Preserving Dharma, Heritage and Humanity</p></div></div></div></div>';
      }

      // ===== PDF GENERATION =====
      async function loadPdfLibs() {
        if (window._pdfLibsLoaded) return;
        const [h2cMod, jsMod] = await Promise.all([
          import('https://esm.sh/html2canvas@1.4.1'),
          import('https://esm.sh/jspdf@2.5.2')
        ]);
        window.html2canvas = h2cMod.default;
        window.jsPDF = jsMod.jsPDF;
        window._pdfLibsLoaded = true;
      }

      function showPdfStatus(msg) {
        let el = document.getElementById('pdf-status');
        if (!el) {
          el = document.createElement('div');
          el.id = 'pdf-status';
          el.style.cssText = 'position:fixed;bottom:20px;right:20px;z-index:9999;background:rgba(13,13,43,0.95);border:1px solid rgba(212,160,23,0.4);color:#f5f0e8;padding:0.75rem 1.5rem;font-family:Inter,sans-serif;font-size:0.85rem;border-radius:6px;backdrop-filter:blur(8px);box-shadow:0 4px 20px rgba(0,0,0,0.3);';
          document.body.appendChild(el);
        }
        el.textContent = msg;
        el.style.display = 'block';
      }
      function hidePdfStatus() {
        const el = document.getElementById('pdf-status');
        if (el) el.style.display = 'none';
      }

      const CAL_URL = 'https://calendar.google.com/calendar/render?action=TEMPLATE&text=The+18+Steps+USA+Inauguration+Ceremony&dates=20260606T210000Z/20260607T030000Z&details=Inauguration+ceremony+of+The+18+Steps+USA+featuring+Chaayamukhi+dance+drama,+spiritual+discourse,+and+professionally+catered+dinner.&location=PYLUSD+Performing+Arts+Center,+1651+Valencia+Ave,+Placentia,+CA+92870';
      const MAP_URL = 'https://www.google.com/maps/dir/?api=1&destination=PYLUSD+Performing+Arts+Center+1651+Valencia+Ave+Placentia+CA+92870';

      async function capturePageToPdf(pageEl, pdf, isFirst) {
        // Temporarily fix size for consistent PDF rendering
        const origStyle = pageEl.getAttribute('style') || '';
        pageEl.style.cssText = origStyle + ';width:816px !important;height:1056px !important;max-height:none !important;aspect-ratio:auto !important;';
        await new Promise(r => setTimeout(r, 150)); // let layout settle

        const canvas = await window.html2canvas(pageEl, {
          scale: 2,
          useCORS: true,
          backgroundColor: null,
          logging: false,
          width: 816,
          height: 1056,
        });

        // Restore original style
        pageEl.setAttribute('style', origStyle);

        const imgData = canvas.toDataURL('image/jpeg', 0.95);
        const pdfW = 8.5;
        const pdfH = 11;
        if (!isFirst) pdf.addPage();
        pdf.addImage(imgData, 'JPEG', 0, 0, pdfW, pdfH);

        // Add clickable link annotations over date and venue areas
        // Find .ev-link elements and map their positions to PDF coordinates
        const links = pageEl.querySelectorAll('.ev-link');
        const pageRect = pageEl.getBoundingClientRect();
        links.forEach(link => {
          const r = link.getBoundingClientRect();
          const x = ((r.left - pageRect.left) / pageRect.width) * pdfW;
          const y = ((r.top - pageRect.top) / pageRect.height) * pdfH;
          const w = (r.width / pageRect.width) * pdfW;
          const h = (r.height / pageRect.height) * pdfH;
          const url = link.getAttribute('href');
          if (url) {
            pdf.link(x, y, w, h, { url: url });
          }
        });

        // Also add links for RSVP and Donate
        const rsvpLinks = pageEl.querySelectorAll('.rsvp-strip a');
        rsvpLinks.forEach(link => {
          const r = link.getBoundingClientRect();
          const x = ((r.left - pageRect.left) / pageRect.width) * pdfW;
          const y = ((r.top - pageRect.top) / pageRect.height) * pdfH;
          const w = (r.width / pageRect.width) * pdfW;
          const h = (r.height / pageRect.height) * pdfH;
          const url = link.getAttribute('href');
          if (url) {
            pdf.link(x, y, w, h, { url: url });
          }
        });
      }

      async function saveSinglePdf() {
        showPdfStatus('Generating PDF...');
        await loadPdfLibs();
        const pdf = new window.jsPDF({ orientation: 'portrait', unit: 'in', format: 'letter' });

        if (selType === 'chaayamukhi') {
          const page = wCh.querySelector('.ch-inv');
          await capturePageToPdf(page, pdf, true);
        } else if (selFmt === '1page') {
          const page = w1.querySelector('.inv-page');
          await capturePageToPdf(page, pdf, true);
        } else {
          const pages = w2.querySelectorAll('.inv-page');
          for (let i = 0; i < pages.length; i++) {
            await capturePageToPdf(pages[i], pdf, i === 0);
          }
        }

        const name = (p1.name.textContent || 'invitation').replace(/[^a-zA-Z0-9]/g, '_');
        pdf.save('Invitation_' + name + '.pdf');
        hidePdfStatus();
      }

      async function saveAllPdf() {
        if (!invitees.length) return;
        showPdfStatus('Generating PDF for all ' + invitees.length + ' invitees...');
        await loadPdfLibs();
        const pdf = new window.jsPDF({ orientation: 'portrait', unit: 'in', format: 'letter' });
        let isFirst = true;

        for (let i = 0; i < invitees.length; i++) {
          showPdfStatus('Generating PDF... (' + (i + 1) + '/' + invitees.length + ')');
          // Apply this invitee to preview
          const v = invitees[i];
          apply(v.name, v.title, v.a1, v.a2, v.csz, v.type);

          // Small delay for DOM to update
          await new Promise(r => setTimeout(r, 100));

          if (v.type === 'chaayamukhi') {
            const page = wCh.querySelector('.ch-inv');
            await capturePageToPdf(page, pdf, isFirst);
            isFirst = false;
          } else if (selFmt === '1page') {
            const page = w1.querySelector('.inv-page');
            await capturePageToPdf(page, pdf, isFirst);
            isFirst = false;
          } else {
            const pages = w2.querySelectorAll('.inv-page');
            for (let j = 0; j < pages.length; j++) {
              await capturePageToPdf(pages[j], pdf, isFirst);
              isFirst = false;
            }
          }
        }

        // Restore current preview
        if (curIdx >= 0 && invitees[curIdx]) {
          const v = invitees[curIdx];
          apply(v.name, v.title, v.a1, v.a2, v.csz, v.type);
        }

        pdf.save('Invitations_All.pdf');
        hidePdfStatus();
      }

      document.getElementById('btn-save-pdf-single').addEventListener('click', saveSinglePdf);
      document.getElementById('btn-pdf-current').addEventListener('click', saveSinglePdf);
      document.getElementById('btn-pdf-all').addEventListener('click', saveAllPdf);
      const bulkBtn = document.getElementById('btn-generate-bulk');
      bulkBtn.addEventListener('click', saveAllPdf);

      function enableBulkBtn() {
        bulkBtn.disabled = false;
        bulkBtn.style.opacity = '1';
        bulkBtn.style.cursor = 'pointer';
        bulkBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg> Generate Bulk Invites (' + invitees.length + ')';
      }

      document.getElementById('btn-bulk-pdf').addEventListener('click', saveAllPdf);
      document.getElementById('btn-bulk-print').addEventListener('click', () => {
        if (!invitees.length) return;
        pac.innerHTML = invitees.map(v => v.type==='chaayamukhi' ? htmlCh(v) : (selFmt==='2page' ? html2p(v) : html1p(v))).join('');
        pac.style.display='block'; window.print();
        setTimeout(()=>{pac.style.display='none';},500);
      });

      // ===== IMAGE DOWNLOAD =====
      async function getInvitationCanvas() {
        await loadPdfLibs();
        let pageEl;
        if (selType === 'chaayamukhi') {
          pageEl = wCh.querySelector('.ch-inv');
        } else if (selFmt === '1page') {
          pageEl = w1.querySelector('.inv-page');
        } else {
          pageEl = w2.querySelector('.inv-page');
        }
        // Temporarily fix size for consistent rendering
        const origStyle = pageEl.getAttribute('style') || '';
        pageEl.style.cssText = origStyle + ';width:816px !important;height:1056px !important;max-height:none !important;aspect-ratio:auto !important;';
        await new Promise(r => setTimeout(r, 150));

        const canvas = await window.html2canvas(pageEl, {
          scale: 2,
          useCORS: true,
          backgroundColor: null,
          logging: false,
          width: 816,
          height: 1056,
        });

        pageEl.setAttribute('style', origStyle);
        return canvas;
      }

      async function saveAsImage() {
        showPdfStatus('Generating image...');
        const canvas = await getInvitationCanvas();
        const link = document.createElement('a');
        const name = (p1.name.textContent || 'invitation').replace(/[^a-zA-Z0-9]/g, '_');
        link.download = 'Invitation_' + name + '.png';
        link.href = canvas.toDataURL('image/png');
        link.click();
        hidePdfStatus();
      }

      async function copyToClipboard() {
        showPdfStatus('Copying to clipboard...');
        try {
          // Use ClipboardItem with a lazy blob promise to preserve user gesture context
          const blobPromise = (async () => {
            const canvas = await getInvitationCanvas();
            return new Promise(resolve => canvas.toBlob(resolve, 'image/png'));
          })();
          await navigator.clipboard.write([
            new ClipboardItem({ 'image/png': blobPromise })
          ]);
          showPdfStatus('Copied to clipboard!');
          setTimeout(hidePdfStatus, 2000);
        } catch (err) {
          // Fallback: open image in new tab for manual copy
          try {
            const canvas = await getInvitationCanvas();
            const dataUrl = canvas.toDataURL('image/png');
            const w = window.open();
            if (w) {
              w.document.write('<img src="' + dataUrl + '" style="max-width:100%;"/>');
              w.document.title = 'Invitation - Right-click to copy';
              showPdfStatus('Opened in new tab — right-click image to copy');
            } else {
              showPdfStatus('Pop-up blocked — try Save Image instead');
            }
          } catch(e2) {
            showPdfStatus('Could not copy — try Save Image instead');
          }
          setTimeout(hidePdfStatus, 3000);
        }
      }

      document.getElementById('btn-save-img-single').addEventListener('click', saveAsImage);
      document.getElementById('btn-img-current').addEventListener('click', saveAsImage);
      document.getElementById('btn-copy-clip-single').addEventListener('click', copyToClipboard);
      document.getElementById('btn-copy-current').addEventListener('click', copyToClipboard);

      function htmlCh(v) {
        const tl=v.title?'<p class="ch-inv-guest-title">'+v.title+'</p>':'';
        const ad=(v.a1||v.a2||v.csz)?'<div class="ch-inv-addr">'+(v.a1?'<p>'+v.a1+'</p>':'')+(v.a2?'<p>'+v.a2+'</p>':'')+(v.csz?'<p>'+v.csz+'</p>':'')+'</div>':'';
        const chDiv='<div class="ch-div"><span class="ch-diamond"></span></div>';
        return '<div class="ch-inv"><div class="ch-inv-hero" style="background-image:url('+base+'/images/chayamughi/2.jpg)"><div class="ch-inv-hero-ov"></div></div><div class="ch-ov-glow"></div><div class="ch-ov-dots"></div><div class="ch-edge-l"></div><div class="ch-edge-r"></div><div class="ch-frame"></div><div class="ch-inv-body"><p class="ch-inv-type">A Musical Dance Drama</p><h1 class="ch-inv-title">Chaayamukhi</h1><p class="ch-inv-subtitle">A Mirror of Desire, A Promise to Nature</p>'+chDiv+'<p class="ch-inv-cordially">cordially invites</p><h2 class="ch-inv-guest">'+v.name+'</h2>'+tl+ad+chDiv+'<div class="ch-inv-event"><p><strong>Saturday, June 6, 2026</strong></p><p>4:50 PM</p><p style="opacity:0.6;font-size:0.5rem">PYLUSD Performing Arts Center</p><p style="opacity:0.4;font-size:0.45rem">1651 Valencia Ave, Placentia, CA 92870</p></div><p class="ch-inv-cast">~40 Performers · Indian Classical & Folk Dance · Kalari Choreography</p><div class="ch-inv-rsvp"><span>RSVP: <a href="https://www.eventbrite.com/e/1984502633799">eventbrite.com</a></span><span style="opacity:0.3">·</span><span>Donate: <a href="https://www.zeffy.com/en-US/ticketing/support-the-18-steps-usa-lucky-draw-raffle">zeffy.com</a></span></div>'+chDiv+'<p class="ch-inv-foot">Thathwamasi — Thou art that</p><p style="font-family:Inter,sans-serif;font-size:0.45rem;opacity:0.3;margin-top:0.3rem;letter-spacing:0.1em;">In collaboration with <span style="font-family:Cinzel,serif;font-weight:600;letter-spacing:0.15em;opacity:1;">The 18 Steps USA</span></p></div></div>';
      }

      // Update print-all to handle chaayamukhi type
      document.getElementById('btn-print-all').removeEventListener('click', null);

      // INIT
      tBtns.forEach(b => { if(b.dataset.type==='regular') b.classList.add('active-regular'); });
      refresh();
      // Pre-load html2canvas in background so clipboard copy works without delay
      setTimeout(() => loadPdfLibs(), 2000);
    </script>
  </body>
