      }

      @keyframes keynote-slide-left {
        from { opacity: 0; transform: translateX(60px); }
        to { opacity: 1; transform: translateX(0); }
      }

      @keyframes shimmer-border {
        0%, 100% { border-color: var(--color-saffron); }
        50% { border-color: var(--color-gold-light); }
      }

      @keyframes shimmer-text {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
      }

      @keyframes pulse-ring {
        0% { transform: scale(1); opacity: 0.6; }
        100% { transform: scale(1.6); opacity: 0; }
      }

      @keyframes bounce-slow {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-6px); }
      }

      @keyframes bg-slow-zoom {
        from { transform: scale(1.1); }
        to { transform: scale(1.2); }
      }

      @keyframes orb-float-1 {
        0%, 100% { transform: translate(0, 0); }
        25% { transform: translate(60px, -30px); }
        50% { transform: translate(20px, 50px); }
        75% { transform: translate(-40px, 20px); }
      }

      @keyframes orb-float-2 {
        0%, 100% { transform: translate(0, 0); }
        33% { transform: translate(-50px, 40px); }
        66% { transform: translate(30px, -30px); }
      }

      @keyframes orb-float-3 {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(-30px, -40px); }
      }

      @keyframes ambient-rise {
        0% { transform: translateY(0) translateX(0); opacity: 0; }
        10% { opacity: 1; }
        90% { opacity: 0.8; }
        100% { transform: translateY(-100vh) translateX(var(--drift, 0px)); opacity: 0; }
      }

      /* Hidden state for unanimated elements */
      .slide:not(.active) [data-anim] {
        opacity: 0;
      }
    </style>
  </body>
</html>
