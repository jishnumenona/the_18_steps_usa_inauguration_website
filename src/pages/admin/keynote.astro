---
import '../../styles/global.css';
const base = import.meta.env.BASE_URL;
const totalSlides = 13;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href={`${base}/images/aesthetic/the_18_steps_logo.jpg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>Sponsor Keynote | The 18 Steps USA</title>
  </head>
  <body class="min-h-screen bg-cosmic text-cream overflow-hidden cursor-pointer">
    <!-- Layered backgrounds -->
    <div class="absolute inset-0 bg-pattern-mandala opacity-20"></div>
    <div class="radial-glow"></div>

    <!-- Ambient golden particles -->
    <div id="ambient-particles" class="absolute inset-0 pointer-events-none z-[5]"></div>

    <!-- Floating orbs -->
    <div class="floating-orb orb-1"></div>
    <div class="floating-orb orb-2"></div>
    <div class="floating-orb orb-3"></div>

    <!-- Navigation Arrows -->
    <button id="nav-prev" class="nav-arrow nav-arrow-left" aria-label="Previous slide">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>
    <button id="nav-next" class="nav-arrow nav-arrow-right" aria-label="Next slide">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <!-- Dot Indicators -->
    <div id="dot-nav" class="dot-nav">
      {[...Array(totalSlides)].map((_, i) => (
        <button class={`dot ${i === 0 ? 'active' : ''}`} data-slide={i} aria-label={`Go to slide ${i + 1}`}></button>
      ))}
    </div>

    <!-- Slide Counter -->
    <div class="slide-counter">
      <span id="slide-current">1</span> / {totalSlides}
    </div>

    <!-- Progress Bar -->
    <div class="progress-bar">
      <div id="progress-fill" class="progress-fill" style="width: 8.33%"></div>
    </div>

    <!-- Slide Deck -->
    <div id="slide-deck" class="slide-deck" data-total={totalSlides}>

      <!-- ==================== SLIDE 1: TITLE ==================== -->
      <section class="slide" data-slide="0">
        <div class="absolute inset-0">
          <img src={`${base}/images/aesthetic/main_vishnu.webp`} alt="Divine backdrop" class="w-full h-full object-cover scale-110 slide-bg-zoom" />
          <div class="absolute inset-0 bg-gradient-to-b from-cosmic/70 via-cosmic/40 to-cosmic"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-cosmic/60 via-transparent to-cosmic/60"></div>
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,transparent_30%,rgba(13,13,43,0.8)_70%)]"></div>
        </div>
        <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-8">
          <div class="relative mb-10" data-anim="scale-in">
            <img src={`${base}/images/aesthetic/the_18_steps_logo.jpg`} alt="The 18 Steps Logo" class="w-36 h-36 rounded-full shadow-2xl img-blend-circle" />
            <div class="absolute inset-0 rounded-full animate-pulse-ring"></div>
            <div class="absolute inset-0 rounded-full animate-pulse-ring" style="animation-delay: 0.5s"></div>
          </div>
          <p class="text-saffron/60 text-sm md:text-base tracking-[0.4em] uppercase mb-4 font-medium" data-anim="enter" data-delay="150">Inaugurating the USA Chapter</p>
          <h1 class="font-display text-7xl md:text-8xl lg:text-[10rem] font-bold text-gradient-gold leading-none mb-6" data-anim="enter" data-delay="300">
            The 18 Steps
          </h1>
          <p class="font-display text-2xl md:text-4xl text-cream/80 tracking-[0.15em] mb-2" data-anim="enter" data-delay="500">
            Inauguration Ceremony
          </p>
          <p class="font-serif text-lg md:text-xl text-cream/60 italic mb-8" data-anim="enter" data-delay="600">
            Preserving Dharma, Heritage and Humanity
          </p>
          <div class="gold-divider" data-anim="enter" data-delay="650"></div>
          <div class="flex items-center gap-8 mt-6 text-lg md:text-xl" data-anim="enter" data-delay="750">
            <span class="text-saffron font-display font-semibold tracking-wider">June 6, 2026</span>
            <span class="text-saffron/40">|</span>
            <span class="text-cream/70">PYLUSD Performing Arts Center</span>
            <span class="text-saffron/40">|</span>
            <span class="text-cream/70">Placentia, California</span>
          </div>
          <div class="mt-12 flex items-center gap-2 text-cream/30 text-sm animate-bounce-slow" data-anim="enter" data-delay="1000">
            <span>Click anywhere or press</span>
            <kbd class="px-2 py-0.5 border border-cream/20 rounded text-cream/50 text-xs">&#8594;</kbd>
            <span>to continue</span>
          </div>
        </div>
      </section>

      <!-- ==================== SLIDE 2: ABOUT THE 18 STEPS ==================== -->
      <section class="slide" data-slide="1">
        <div class="absolute inset-0 overflow-hidden">
          <img src={`${base}/images/aesthetic/krishna.jpg`} alt="Krishna" class="absolute right-0 top-0 w-[55%] h-full object-cover img-blend-left" />
        </div>
        <div class="relative z-10 flex items-center h-full">
          <div class="w-[55%] pl-16 lg:pl-24 pr-8">
            <p class="text-saffron/70 text-sm tracking-[0.3em] uppercase mb-4" data-anim="slide-right">A Global Movement</p>
            <h2 class="font-display text-5xl md:text-7xl font-bold text-gradient-gold mb-8 leading-tight" data-anim="slide-right" data-delay="100">The 18 Steps</h2>
            <div class="space-y-5 text-cream/80 text-lg leading-relaxed" data-anim="enter" data-delay="250">
              <p>Founded in <span class="text-saffron font-semibold">2018</span> as a YouTube channel by <span class="text-saffron">Sharath A. Haridasan</span>, The 18 Steps has grown into a powerful global non-profit movement — dedicated to preserving and sharing the timeless wisdom of <span class="text-saffron font-semibold">Sanatana Dharma</span>.</p>
              <p>Through lectures, courses, workshops, and digital initiatives, the movement spans <span class="text-saffron">multiple countries</span> — engaging communities in heritage conservation, temple renovation, Vedic studies, and humanitarian service.</p>
            </div>
            <div class="flex gap-10 mt-12" data-anim="enter" data-delay="450">
              <div class="text-center">
                <p class="font-display text-5xl font-bold text-gradient-gold"><span class="count-up" data-target="105" data-suffix="K+">0</span></p>
                <p class="text-cream/50 text-sm mt-2 tracking-wider uppercase">YouTube Subscribers</p>
              </div>
              <div class="text-center">
                <p class="font-display text-5xl font-bold text-gradient-gold"><span class="count-up" data-target="600" data-suffix="+">0</span></p>
                <p class="text-cream/50 text-sm mt-2 tracking-wider uppercase">Videos Published</p>
              </div>
              <div class="text-center">
                <p class="font-display text-5xl font-bold text-gradient-gold"><span class="count-up" data-target="8" data-suffix="+">0</span></p>
                <p class="text-cream/50 text-sm mt-2 tracking-wider uppercase">Countries Reached</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ==================== SLIDE 3: SHARATH A. HARIDASAN ==================== -->
      <section class="slide" data-slide="2">
        <div class="absolute inset-0 overflow-hidden">
          <img src={`${base}/images/aesthetic/sharath_a_haridasan_1.jpg`} alt="Sharath A. Haridasan" class="absolute left-0 top-0 w-[48%] h-full object-cover img-blend-right" />
        </div>
        <div class="relative z-10 flex items-center h-full">
          <div class="w-[48%]"></div>
          <div class="w-[52%] pr-16 lg:pr-24 pl-8">
            <p class="text-saffron/70 text-sm tracking-[0.3em] uppercase mb-4" data-anim="slide-left">Founder &amp; Visionary</p>
            <h2 class="font-display text-4xl md:text-6xl font-bold text-gradient-gold mb-3 leading-tight" data-anim="slide-left" data-delay="100">Sharath A.<br/>Haridasan</h2>
            <p class="text-cream/60 text-xl mb-8 italic font-serif" data-anim="enter" data-delay="200">Filmmaker &middot; Vedic Scholar &middot; Spiritual Orator &middot; Author</p>

            <blockquote class="border-l-2 border-saffron/50 pl-5 text-cream/60 italic text-base mb-8" data-anim="enter" data-delay="300">
              "A spiritual teacher who blends ancient wisdom with modern insights — inspiring seekers worldwide through film, word, and devotion."
            </blockquote>

            <div class="grid grid-cols-1 gap-3 text-cream/75 text-[15px]" data-anim="enter" data-delay="400">
              <div class="flex items-start gap-3">
                <span class="text-saffron mt-0.5 text-lg">&#9670;</span>
                <span><strong class="text-cream">30+ years</strong> in film &amp; media — directed Mammootty's first Kalyan TVC</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-saffron mt-0.5 text-lg">&#9670;</span>
                <span>Founded <strong class="text-cream">Cinetra Media FZE</strong> (Dubai) &amp; <strong class="text-cream">Blue Planet Cinema</strong></span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-saffron mt-0.5 text-lg">&#9670;</span>
                <span>Produced for <strong class="text-cream">AR Rahman, Royal Enfield, National Geographic, Discovery Channel</strong></span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-saffron mt-0.5 text-lg">&#9670;</span>
                <span>"The Dominion" — <strong class="text-cream">Best Experimental Film</strong> &middot; "Salala Mobiles" (Dulquer Salmaan)</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-saffron mt-0.5 text-lg">&#9670;</span>
                <span>"Akhilam Madhuram" &middot; "Art of Dust" (Amazon Prime) &middot; "The Ritual of Fire"</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ==================== SLIDE 4: VEDIC SCHOLAR & AUTHOR ==================== -->
      <section class="slide" data-slide="3">
        <div class="absolute inset-0 overflow-hidden">
          <img src={`${base}/images/aesthetic/sharath_a_haridasan_2.jpg`} alt="Sharath A. Haridasan" class="absolute right-0 top-0 w-[40%] h-full object-cover img-blend-left" />
        </div>
        <div class="relative z-10 flex h-full">
          <div class="w-[60%] flex flex-col justify-center pl-16 lg:pl-24 pr-8">
            <p class="text-saffron/70 text-sm tracking-[0.3em] uppercase mb-4" data-anim="enter">Vedic Scholar &amp; Author</p>
            <h2 class="font-display text-4xl md:text-6xl font-bold text-gradient-gold mb-8 leading-tight" data-anim="enter" data-delay="100">Knowledge &amp; Legacy</h2>

            <div class="space-y-3 text-cream/75 text-base leading-relaxed mb-10" data-anim="enter" data-delay="200">
              <p>Fluent in <strong class="text-saffron">Sanskrit, Malayalam, Tamil, Hindi &amp; English</strong>. A revered speaker at the sacred temples of <strong class="text-cream">Guruvayur, Mammiyur &amp; Kalpathy</strong>.</p>
              <p>Member of the <strong class="text-cream">KDRB expert committee</strong>. Instrumental in restructuring the <strong class="text-saffron">Tantra Vidya curriculum</strong> — shaping the next generation of Vedic scholarship.</p>
            </div>

            <div class="flex gap-6" data-anim="enter" data-delay="400">
              <div class="book-card group">
                <img src={`${base}/images/books/18_meditations_for_alife_of_purpose_and_prosperity.jpg`} alt="Krishna's Whisper" class="book-cover" />
                <div class="book-info">
                  <h3 class="font-display text-sm text-saffron font-semibold leading-tight">Krishna's Whisper:<br/>18 Meditations</h3>
                  <p class="text-cream/40 text-xs mt-1">World Book Fair</p>
                  <p class="text-saffron/60 text-xs">NBT Hall of Fame</p>
                </div>
              </div>
              <div class="book-card group">
                <img src={`${base}/images/books/51_zen_stories_to_wake_up.jpg`} alt="51 Zen Stories" class="book-cover" />
                <div class="book-info">
                  <h3 class="font-display text-sm text-saffron font-semibold leading-tight">51 Zen Stories<br/>to Wake Up</h3>
                  <p class="text-cream/40 text-xs mt-1">Spiritual Wisdom</p>
                </div>
              </div>
              <div class="book-card group">
                <img src={`${base}/images/books/a_very_simple_guide_to_bhagavad_gita.jpg`} alt="Bhagavad Gita" class="book-cover" />
                <div class="book-info">
                  <h3 class="font-display text-sm text-saffron font-semibold leading-tight">A Very Simple Guide<br/>to Bhagavad Gita</h3>
                  <p class="text-cream/40 text-xs mt-1">Accessible Wisdom</p>
                </div>
              </div>
              <div class="book-card group">
                <img src={`${base}/images/books/Art_of_dust.jpg`} alt="Art of Dust" class="book-cover" />
                <div class="book-info">
                  <h3 class="font-display text-sm text-saffron font-semibold leading-tight">Art of Dust</h3>
                  <p class="text-cream/40 text-xs mt-1">Amazon Prime</p>
                  <p class="text-saffron/60 text-xs">Kalamezhuthu</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ==================== SLIDE 5: THE 18 STEPS USA ==================== -->
      <section class="slide" data-slide="4">
        <div class="absolute inset-0 overflow-hidden">
          <img src={`${base}/images/aesthetic/main_vishnu.webp`} alt="Background" class="w-full h-full object-cover opacity-15 scale-125" />
        </div>
        <div class="relative z-10 flex flex-col items-center justify-center h-full px-12 text-center">
          <div class="relative mb-8" data-anim="scale-in">
            <img src={`${base}/images/aesthetic/the_18_steps_logo.jpg`} alt="Logo" class="w-28 h-28 rounded-full img-blend-circle" />
            <div class="absolute inset-0 rounded-full animate-pulse-ring"></div>
          </div>
          <h2 class="font-display text-5xl md:text-7xl font-bold text-gradient-gold mb-3" data-anim="enter" data-delay="100">The 18 Steps USA</h2>
          <p class="font-serif text-xl text-cream/60 italic mb-12 max-w-2xl" data-anim="enter" data-delay="200">Preserving Dharma, Heritage and Humanity on American shores</p>

          <div class="grid grid-cols-4 gap-5 max-w-5xl w-full" data-anim="enter" data-delay="300">
            <div class="pillar-card">
              <div class="pillar-icon">
                <svg class="w-10 h-10 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
              </div>
              <h3 class="font-display text-saffron font-semibold text-lg mb-2">Heritage Conservation</h3>
              <p class="text-cream/50 text-sm leading-relaxed">Documenting and preserving ancient temples, rituals, and cultural traditions across India and beyond</p>
            </div>
            <div class="pillar-card">
              <div class="pillar-icon">
                <svg class="w-10 h-10 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm0 8a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6z" /></svg>
              </div>
              <h3 class="font-display text-saffron font-semibold text-lg mb-2">Temple Renovation</h3>
              <p class="text-cream/50 text-sm leading-relaxed">Restoring sacred spaces to their former glory — reconnecting communities with their spiritual roots</p>
            </div>
            <div class="pillar-card">
              <div class="pillar-icon">
                <svg class="w-10 h-10 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
              </div>
              <h3 class="font-display text-saffron font-semibold text-lg mb-2">Vedic Education</h3>
              <p class="text-cream/50 text-sm leading-relaxed">Teaching timeless spiritual wisdom through courses, workshops, and digital content reaching millions</p>
            </div>
            <div class="pillar-card">
              <div class="pillar-icon">
                <svg class="w-10 h-10 text-saffron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
              </div>
              <h3 class="font-display text-saffron font-semibold text-lg mb-2">Humanitarian Service</h3>
              <p class="text-cream/50 text-sm leading-relaxed">Serving communities with compassion — food drives, medical camps, and disaster relief across nations</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ==================== SLIDE 6: THE INAUGURATION EVENT ==================== -->
      <section class="slide" data-slide="5">
        <div class="absolute inset-0 overflow-hidden">
          <img src={`${base}/images/event/1.jpg`} alt="Event" class="absolute right-0 top-0 w-[45%] h-full object-cover img-blend-left" />
        </div>
        <div class="relative z-10 flex h-full">
          <div class="w-[58%] flex flex-col justify-center pl-16 lg:pl-24 pr-8">
            <p class="text-saffron/70 text-sm tracking-[0.3em] uppercase mb-4" data-anim="enter">A Historic Gathering</p>
            <h2 class="font-display text-4xl md:text-6xl font-bold text-gradient-gold mb-8 leading-tight" data-anim="enter" data-delay="100">The Inauguration</h2>

            <div class="flex gap-5 mb-8" data-anim="enter" data-delay="200">
              <div class="event-detail-card">
                <p class="font-display text-4xl font-bold text-gradient-gold">June 6</p>
                <p class="text-cream/50 text-sm mt-1">Saturday, 2026</p>
              </div>
              <div class="event-detail-card">
                <p class="font-display text-xl font-bold text-saffron">2:00 – 8:00 PM</p>
                <p class="text-cream/50 text-sm mt-1">Pacific Standard Time</p>
              </div>
            </div>

            <div class="card-dark p-5 mb-8 border-saffron/20" data-anim="enter" data-delay="300">
              <p class="text-saffron font-display font-semibold text-lg mb-1">PYLUSD Performing Arts Center</p>
              <p class="text-cream/60 text-sm">1651 Valencia Ave, Placentia, CA 92870</p>
              <div class="flex gap-4 mt-3 text-cream/50 text-xs">
                <span>Fully equipped theatrical stage</span>
                <span class="text-saffron/40">&middot;</span>
                <span>Professional lighting &amp; sound</span>
                <span class="text-saffron/40">&middot;</span>
                <span>24' x 10' LED wall</span>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-x-6 gap-y-2 text-cream/70 text-sm" data-anim="enter" data-delay="400">
              <div class="flex items-center gap-2"><span class="text-saffron">&#10003;</span> Non-ticketed community event</div>
              <div class="flex items-center gap-2"><span class="text-saffron">&#10003;</span> Professionally catered dinner</div>
              <div class="flex items-center gap-2"><span class="text-saffron">&#10003;</span> Cultural performances &amp; discourse</div>
              <div class="flex items-center gap-2"><span class="text-saffron">&#10003;</span> $1,500 raffle draw</div>
              <div class="flex items-center gap-2"><span class="text-saffron">&#10003;</span> Representatives from across the USA</div>
              <div class="flex items-center gap-2"><span class="text-saffron">&#10003;</span> First pro dance drama in LA in 10 years</div>
            </div>

            <div class="flex gap-10 mt-8" data-anim="enter" data-delay="500">
              <div class="text-center">
                <p class="font-display text-4xl font-bold text-gradient-gold"><span class="count-up" data-target="500" data-suffix="+">0</span></p>
                <p class="text-cream/50 text-xs mt-1 uppercase tracking-wider">Attendees</p>
              </div>
              <div class="text-center">
                <p class="font-display text-4xl font-bold text-gradient-gold"><span class="count-up" data-target="50" data-suffix="+">0</span></p>
                <p class="text-cream/50 text-xs mt-1 uppercase tracking-wider">Community Leaders</p>
              </div>
              <div class="text-center">
                <p class="font-display text-4xl font-bold text-gradient-gold">6<span class="text-2xl">hrs</span></p>
                <p class="text-cream/50 text-xs mt-1 uppercase tracking-wider">of Programming</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ==================== SLIDE 7: EVENT PROGRAM ==================== -->
      <section class="slide" data-slide="6">
        <div class="relative z-10 flex flex-col items-center justify-center h-full px-16 lg:px-24">
          <p class="text-saffron/70 text-sm tracking-[0.3em] uppercase mb-4" data-anim="enter">June 6, 2026</p>
          <h2 class="font-display text-4xl md:text-6xl font-bold text-gradient-gold mb-10" data-anim="enter" data-delay="100">Event Program</h2>

          <div class="grid grid-cols-2 gap-x-16 gap-y-0 max-w-5xl w-full" data-anim="enter" data-delay="200">
            <div class="schedule-item"><span class="schedule-time">2:00 PM</span><span class="schedule-name">Invocation &amp; Prayer</span></div>
            <div class="schedule-item"><span class="schedule-time">3:25 PM</span><span class="schedule-name">Honoring Special Participants</span></div>
            <div class="schedule-item"><span class="schedule-time">2:05 PM</span><span class="schedule-name">Welcome Address</span></div>
            <div class="schedule-item"><span class="schedule-time">3:30 PM</span><span class="schedule-name">Felicitations</span></div>
            <div class="schedule-item schedule-highlight"><span class="schedule-time">2:10 PM</span><span class="schedule-name">Inauguration Ceremony</span></div>
            <div class="schedule-item"><span class="schedule-time">3:45 PM</span><span class="schedule-name">Vote of Thanks</span></div>
            <div class="schedule-item schedule-highlight"><span class="schedule-time">2:15 PM</span><span class="schedule-name">Keynote Address</span></div>
            <div class="schedule-item"><span class="schedule-time">3:50 PM</span><span class="schedule-name">Tea Break</span></div>
