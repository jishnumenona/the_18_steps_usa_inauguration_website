    <script define:vars={{ totalSlides }}>
      // ===== STATE =====
      let currentSlide = 0;
      let isTransitioning = false;
      let touchStartX = 0;
      const TOTAL = totalSlides;

      // ===== DOM =====
      const deck = document.getElementById('slide-deck');
      const dots = document.querySelectorAll('.dot');
      const prevBtn = document.getElementById('nav-prev');
      const nextBtn = document.getElementById('nav-next');
      const slideCurrentEl = document.getElementById('slide-current');
      const progressFill = document.getElementById('progress-fill');
      const slides = document.querySelectorAll('.slide');

      // ===== NAVIGATION =====
      function goToSlide(index) {
        if (isTransitioning || index < 0 || index >= TOTAL || index === currentSlide) return;
        isTransitioning = true;

        // Deactivate old slide
        slides[currentSlide].classList.remove('active');
        resetCountUps(slides[currentSlide]);

        currentSlide = index;
        deck.style.transform = `translateX(-${currentSlide * 100}vw)`;

        // Update UI
        dots.forEach((d, i) => d.classList.toggle('active', i === currentSlide));
        slideCurrentEl.textContent = String(currentSlide + 1);
        progressFill.style.width = `${((currentSlide + 1) / TOTAL) * 100}%`;

        // Arrow visibility
        prevBtn.style.opacity = currentSlide === 0 ? '0.15' : '1';
        prevBtn.style.pointerEvents = currentSlide === 0 ? 'none' : 'auto';
        nextBtn.style.opacity = currentSlide === TOTAL - 1 ? '0.15' : '1';
        nextBtn.style.pointerEvents = currentSlide === TOTAL - 1 ? 'none' : 'auto';

        // Activate new slide after transition
        setTimeout(() => {
          slides[currentSlide].classList.add('active');
          triggerAnimations(slides[currentSlide]);
          triggerCountUps(slides[currentSlide]);
          isTransitioning = false;
        }, 600);
      }

      // Keyboard
      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); goToSlide(currentSlide + 1); }
        else if (e.key === 'ArrowLeft') { e.preventDefault(); goToSlide(currentSlide - 1); }
        else if (e.key === 'Home') { e.preventDefault(); goToSlide(0); }
        else if (e.key === 'End') { e.preventDefault(); goToSlide(TOTAL - 1); }
        else if (e.key === 'f' || e.key === 'F') { e.preventDefault(); toggleFullscreen(); }
      });

      // Click arrows
      prevBtn.addEventListener('click', (e) => { e.stopPropagation(); goToSlide(currentSlide - 1); });
      nextBtn.addEventListener('click', (e) => { e.stopPropagation(); goToSlide(currentSlide + 1); });

      // Dots
      dots.forEach(dot => {
        dot.addEventListener('click', (e) => {
          e.stopPropagation();
          goToSlide(parseInt(dot.dataset.slide || '0'));
        });
      });

      // Click anywhere to advance
      document.addEventListener('click', (e) => {
        const target = e.target;
        // Don't advance if clicking interactive elements
        if (target.closest('.nav-arrow, .dot-nav, a, button:not(.slide)')) return;
        goToSlide(currentSlide + 1);
      });

      // Touch/swipe
      document.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
      document.addEventListener('touchend', (e) => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        if (Math.abs(dx) > 50) {
          if (dx < 0) goToSlide(currentSlide + 1);
          else goToSlide(currentSlide - 1);
        }
      }, { passive: true });

      // ===== ANIMATIONS =====
      function triggerAnimations(slide) {
        const animEls = slide.querySelectorAll('[data-anim]');
        animEls.forEach(el => {
          const delay = parseInt(el.dataset.delay || '0');
          const animType = el.dataset.anim;
          el.style.opacity = '0';
          el.style.animation = 'none';
          setTimeout(() => {
            el.style.animation = `keynote-${animType} 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards`;
          }, delay);
        });
      }

      // ===== COUNT-UP =====
      function triggerCountUps(slide) {
        const counters = slide.querySelectorAll('.count-up');
        counters.forEach(counter => {
          const target = parseInt(counter.dataset.target || '0');
          const suffix = counter.dataset.suffix || '';
          animateCount(counter, target, suffix);
        });
      }

      function resetCountUps(slide) {
        const counters = slide.querySelectorAll('.count-up');
        counters.forEach(counter => { counter.textContent = '0'; });
      }

      function animateCount(el, target, suffix) {
        const duration = 2000;
        const startTime = performance.now();
        function easeOutQuart(t) { return 1 - Math.pow(1 - t, 4); }
        function tick(now) {
          const progress = Math.min((now - startTime) / duration, 1);
          const value = Math.round(easeOutQuart(progress) * target);
          el.textContent = value + (progress >= 1 ? suffix : '');
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }

      // ===== FULLSCREEN =====
      function toggleFullscreen() {
        if (!document.fullscreenElement) document.documentElement.requestFullscreen().catch(() => {});
        else document.exitFullscreen().catch(() => {});
      }

      // ===== AMBIENT PARTICLES =====
      function spawnAmbientParticle() {
        const container = document.getElementById('ambient-particles');
        if (!container) return;
        const particle = document.createElement('div');
        const size = Math.random() * 4 + 1;
        const left = Math.random() * 100;
        const duration = 8 + Math.random() * 14;
        const drift = (Math.random() - 0.5) * 120;
        particle.style.cssText = `
          position:absolute;bottom:-10px;left:${left}%;
          width:${size}px;height:${size}px;
          background:rgba(212,160,23,${0.15 + Math.random() * 0.35});
          border-radius:50%;pointer-events:none;
          box-shadow:0 0 ${size * 2}px rgba(212,160,23,${0.1 + Math.random() * 0.2});
          animation:ambient-rise ${duration}s linear forwards;
          --drift:${drift}px;
        `;
        container.appendChild(particle);
        setTimeout(() => particle.remove(), duration * 1000);
      }

      setInterval(spawnAmbientParticle, 400);
      for (let i = 0; i < 20; i++) setTimeout(spawnAmbientParticle, i * 150);

      // ===== INIT =====
      slides[0].classList.add('active');
      triggerAnimations(slides[0]);
      prevBtn.style.opacity = '0.15';
      prevBtn.style.pointerEvents = 'none';
    </script>

