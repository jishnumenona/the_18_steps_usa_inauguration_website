---

<Layout title="Socials & Links | The 18 Steps USA">

  <section class="relative min-h-screen py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-royal/20 via-cosmic to-cosmic"></div>
    <div class="absolute inset-0 bg-pattern-mandala opacity-30"></div>

    <div class="relative z-10 max-w-lg mx-auto px-4">
      <!-- Profile Header -->
      <div class="text-center mb-10">
        <img
          src={`${base}/images/aesthetic/the_18_steps_logo.jpg`}
          alt="The 18 Steps USA"
          class="w-24 h-24 rounded-full border-2 border-saffron/50 mx-auto mb-4 shadow-[0_0_30px_rgba(212,160,23,0.3)]"
        />
        <h1 class="font-display text-2xl text-saffron font-bold tracking-wider">THE 18 STEPS USA</h1>
        <p class="text-cream/60 text-sm mt-1">Preserving Dharma, Heritage and Humanity</p>
        <p class="text-saffron/70 text-xs mt-2 tracking-widest uppercase">Inauguration — June 6, 2026</p>
      </div>

      <!-- Link Groups -->
      {links.map((group) => (
        <div class="mb-8">
          <p class="text-saffron/60 text-xs tracking-[0.2em] uppercase font-medium mb-3 text-center">{group.category}</p>
          <div class="space-y-3">
            {group.items.map((item) => (
              <a
                href={item.url}
                target={item.url.startsWith('mailto:') || item.url.startsWith('tel:') ? '_self' : '_blank'}
                rel="noopener"
                class="group flex items-center gap-4 bg-cosmic-light/40 border border-saffron/15 rounded-xl px-5 py-4 hover:border-saffron/50 hover:bg-cosmic-light/60 hover:scale-[1.02] hover:shadow-[0_0_20px_rgba(212,160,23,0.15)] transition-all duration-300"
              >
                <div class="w-10 h-10 rounded-full bg-saffron/10 flex items-center justify-center flex-shrink-0 group-hover:bg-saffron/20 transition-colors">
                  <svg class="w-5 h-5 text-saffron" fill="currentColor" viewBox="0 0 24 24" set:html={icons[item.icon]} />
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-cream font-medium text-sm group-hover:text-saffron transition-colors">{item.name}</p>
                  <p class="text-cream/40 text-xs truncate">{item.description}</p>
                </div>
                <svg class="w-4 h-4 text-cream/30 group-hover:text-saffron group-hover:translate-x-1 transition-all flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            ))}
          </div>
        </div>
      ))}

      <!-- Back to main site -->
      <div class="text-center mt-10">
        <a href={`${base}/`} class="text-saffron/60 hover:text-saffron text-xs tracking-wider uppercase transition-colors">
          Back to Main Site
        </a>
      </div>
    </div>
  </section>

</Layout>
